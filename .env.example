# ==============================================================================
# ResumeIQ AI Environment Variables Template
# Copy this file to '.env' and populate the actual secrets for local deployment.
# ==============================================================================

# Database Settings
# Local MongoDB connection (used by default in docker-compose)
# For production, replace with your MongoDB Atlas URI string
MONGODB_URI=mongodb://localhost:27017/resumeiq

# Server Port
PORT=5000

# Environment Mode
NODE_ENV=development

# JWT Authentication Secrets
# Securely generate strings of 32+ characters for access and refresh key signatures
JWT_ACCESS_SECRET=replace_with_a_secure_long_random_jwt_access_secret_key
JWT_REFRESH_SECRET=replace_with_a_secure_long_random_jwt_refresh_secret_key

# Google Gemini AI API Configuration
# Get your API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_google_gemini_api_key_here

# Frontend Application Origin (CORS Configuration)
CLIENT_URL=http://localhost:3000

# SMTP Transactions Mail Server (Nodemailer Configuration)
# For development, you can use Mailtrap or any standard SMTP server
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username_here
SMTP_PASS=your_smtp_password_here
EMAIL_FROM=no-reply@resumeiq-ai.com

# Google OAuth Credentials (Optional)
# Set up OAuth 2.0 Credentials in your Google Cloud Console
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here
