# ==============================================================================
# ResumeIQ AI Backend Environment Variables
# Copy to '.env' inside the backend folder for independent local testing.
# ==============================================================================

PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/resumeiq
JWT_ACCESS_SECRET=replace_with_a_secure_long_random_jwt_access_secret_key
JWT_REFRESH_SECRET=replace_with_a_secure_long_random_jwt_refresh_secret_key
GEMINI_API_KEY=your_google_gemini_api_key_here
CLIENT_URL=http://localhost:3000
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@resumeiq-ai.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
